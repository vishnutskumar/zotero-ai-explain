{
  "name": "zotero-ai-explain",
  "version": "0.2.0",
  "private": true,
  "description": "Zotero plugin for selected-text AI explanations and sidebar follow-up chat.",
  "type": "module",
  "scripts": {
    "build": "esbuild src/bootstrap.ts --bundle --format=iife --global-name=ZoteroAiExplain --platform=browser --target=firefox115 --outfile=addon/content/zotero-ai-explain.js && tsc --noEmit",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint . --max-warnings=0",
    "package": "node scripts/package-xpi.mjs",
    "package:list": "node scripts/list-xpi-contents.mjs zotero-ai-explain.xpi",
    "proxy:llm": "node scripts/llm-proxy/server.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:check": "npm run test:coverage && node scripts/precommit-coverage.mjs",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:local": "vitest run --config vitest.e2e-local.config.ts",
    "test:e2e:harness": "node scripts/zotero-e2e/spawn.mjs",
    "test:e2e:smoke": "node scripts/zotero-e2e/marionette-smoke.mjs",
    "test:e2e:cleanup": "node scripts/zotero-e2e/cleanup.mjs",
    "test:e2e:dump-tokens": "node scripts/zotero-e2e/dump-tokens.mjs",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run lint && npm run format && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/node": "^22.15.17",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.25.12",
    "eslint": "^9.26.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0",
    "vitest": "^3.1.3"
  },
  "engines": {
    "node": ">=22"
  }
}
